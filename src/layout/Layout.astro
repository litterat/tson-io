---
import '../styles/global.css';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
}

const { title, description, image, type, publishedTime, modifiedTime, noindex } = Astro.props;
const siteTitle = 'tson.io';
const home = title === siteTitle;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      home={home}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      noindex={noindex}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-white text-gray-900 min-h-screen flex flex-col">
    <header class="border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-lg font-mono font-semibold tracking-tight hover:text-gray-600">
          tson.io
        </a>
        <nav class="flex items-center gap-6 text-sm text-gray-600">
          <a href="/2026" class="hover:text-gray-900">Specification</a>
          <a href="/research" class="hover:text-gray-900">Research</a>
          <a href="https://github.com/litterat/tson-io" rel="noopener" target="_blank" class="hover:text-gray-900">GitHub</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-gray-200 mt-16">
      <div class="max-w-5xl mx-auto px-6 py-8 text-sm text-gray-500 flex justify-between items-start">
        <div>
          <span>tson.io</span>
          <div class="text-xs text-gray-400 mt-1">
            &copy; 2026{' '}
            <a
              href="https://litterat.io"
              rel="noopener"
              target="_blank"
              class="underline hover:text-gray-600"
            >Litterat Pty Ltd</a>.
          </div>
        </div>
        <div class="text-right">
          <span>Typed Schema Object Notation</span>
          <div class="text-xs text-gray-400 mt-1">
            Content licensed under{' '}
            <a
              href="https://creativecommons.org/licenses/by-sa/4.0/"
              rel="license noopener"
              target="_blank"
              class="underline hover:text-gray-600"
            >CC BY-SA 4.0</a>.
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
