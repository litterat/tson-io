---
// src/components/SEO.astro
// Single source of truth for <head> SEO: title, description, canonical,
// Open Graph, Twitter cards, and JSON-LD structured data.
// Rendered from within Layout.astro's <head> — see Layout.astro for wiring.
//
// PREREQUISITE: astro.config.mjs must set `site: "https://tson.io"`,
// otherwise Astro.site is undefined and canonical/OG URLs won't build.

interface Props {
  /** Page-specific title. */
  title: string;
  /** Meta description for this page. Falls back to a sitewide default when omitted. */
  description?: string;
  /** Root-relative path to a social image, if this page has one. Omitted entirely when absent. */
  image?: string;
  /** "website" for normal pages, "article" for spec/research documents. */
  type?: "website" | "article";
  /** True for the homepage — uses `title` verbatim with no " — tson.io" suffix. */
  home?: boolean;
  /** ISO date strings — only emitted when type === "article". */
  publishedTime?: string;
  modifiedTime?: string;
  /** Set true on pages you don't want indexed (e.g. redirect stubs). */
  noindex?: boolean;
}

const {
  title,
  description,
  image,
  type = "website",
  home = false,
  publishedTime,
  modifiedTime,
  noindex = false,
} = Astro.props;

const SITE_NAME = "tson.io";
const TWITTER_HANDLE = ""; // e.g. "@litterat" — leave empty if you don't have one
const DEFAULT_DESCRIPTION =
  "TSON (Tagged Structure Object Notation) is a Unicode-first, typed superset of JSON with closed-world, SHA-256-verifiable schemas.";

const origin = Astro.site?.origin ?? "https://tson.io";
const canonical = new URL(Astro.url.pathname, origin).href;
const ogImage = image ? new URL(image, origin).href : undefined;
const fullTitle = home ? title : `${title} — ${SITE_NAME}`;
const metaDescription = description ?? DEFAULT_DESCRIPTION;

// --- JSON-LD structured data -------------------------------------------------
const publisher = {
  "@type": "Organization",
  "@id": `${origin}/#litterat`,
  name: "Litterat Pty Ltd",
  url: "https://litterat.io",
};

const website = {
  "@type": "WebSite",
  "@id": `${origin}/#website`,
  url: origin,
  name: SITE_NAME,
  alternateName: "TSON — Tagged Structure Object Notation",
  description: DEFAULT_DESCRIPTION,
  publisher: { "@id": `${origin}/#litterat` },
  inLanguage: "en",
};

const graph: Record<string, unknown>[] = [publisher, website];

if (type === "article") {
  graph.push({
    "@type": "TechArticle",
    "@id": `${canonical}#article`,
    headline: title,
    description: metaDescription,
    url: canonical,
    ...(ogImage && { image: ogImage }),
    inLanguage: "en",
    isPartOf: { "@id": `${origin}/#website` },
    mainEntityOfPage: canonical,
    author: { "@id": `${origin}/#litterat` },
    publisher: { "@id": `${origin}/#litterat` },
    license: "https://creativecommons.org/licenses/by-sa/4.0/",
    ...(publishedTime && { datePublished: publishedTime }),
    ...(modifiedTime && { dateModified: modifiedTime }),
  });
}

const jsonLd = { "@context": "https://schema.org", "@graph": graph };
---

{/* Primary meta */}
<title>{fullTitle}</title>
<meta name="description" content={metaDescription} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

{/* Open Graph */}
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:url" content={canonical} />
{ogImage && (
  <>
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
  </>
)}
{type === "article" && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === "article" && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}

{/* Twitter */}
<meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={metaDescription} />
{ogImage && <meta name="twitter:image" content={ogImage} />}
{TWITTER_HANDLE && <meta name="twitter:site" content={TWITTER_HANDLE} />}

{/* Structured data */}
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
