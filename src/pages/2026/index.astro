---
// The real redirect happens at the edge via public/_redirects (a true 302).
// This page is a static fallback for environments that don't apply it
// (local `astro preview`/dev), and for clients that ignore meta-refresh.
import { CURRENT_REVISION } from '../../lib/spec';

const target = `/2026/${CURRENT_REVISION}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting… — tson.io</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>the latest specification revision</a>.</p>
  </body>
</html>
