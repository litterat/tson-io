---
import Layout from '../../layout/Layout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('spec');
entries.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Layout title="Specification" description="The TSON specification and reference documents.">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold mb-2">Specification</h1>
    <p class="text-gray-600 mb-12">
      The TSON specification documents and reference materials.
    </p>

    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-6 pb-2 border-b border-gray-200">Documents</h2>
      <ul class="space-y-6">
        {entries.map(entry => (
          <li>
            <a href={`/2026-28/${entry.id}`} class="font-medium text-lg hover:underline">
              {entry.data.title}
            </a>
            <div class="flex items-center gap-3 mt-1 text-sm text-gray-500">
              <span>Draft {entry.data.draft}</span>
              <span>·</span>
              <span>{entry.data.status}</span>
            </div>
            {entry.data.description && (
              <p class="text-sm text-gray-500 mt-1">{entry.data.description}</p>
            )}
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2 class="text-xl font-semibold mb-6 pb-2 border-b border-gray-200">Schema Source Files</h2>
      <p class="text-sm text-gray-600 mb-4">
        The normative TSON schema source files in <code class="font-mono bg-gray-100 px-1 rounded">.tn1</code> format.
      </p>
      <ul class="space-y-2 font-mono text-sm">
        {['meta-kernel.tn1', 'meta.tn1', 'core.tn1'].map(file => (
          <li>
            <a href={`/2026-28/${file}`} class="text-gray-700 hover:text-gray-900 hover:underline">
              {file}
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</Layout>
